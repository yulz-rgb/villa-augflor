# Copy to .env locally. On Vercel: Project → Settings → Environment Variables (Production + Preview).

# --- Site (used by Stripe redirect URLs) ---
SITE_URL=https://www.villa-augflor.com

# --- Stripe (https://dashboard.stripe.com/apikeys) ---
STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# --- Calendar: secret iCal export URLs (never commit real URLs; paste only in Vercel env) ---
# Airbnb: Hosting → Calendar → Availability settings → Export calendar → copy secret link
AIRBNB_ICAL_URL=
# Booking.com: Extranet → Calendar → Sync calendars → iCal export link (if you use Booking)
BOOKING_ICAL_URL=
