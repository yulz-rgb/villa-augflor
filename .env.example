# Copy to .env locally. On Vercel: Project → Settings → Environment Variables (Production + Preview).

# --- Site ---
SITE_URL=https://www.villa-augflor.com

# --- Calendar: secret iCal export URLs (never commit real URLs; paste only in Vercel env) ---
# Airbnb: Hosting → Calendar → Availability settings → Export calendar → copy secret link
AIRBNB_ICAL_URL=
# Booking.com: Extranet → Calendar → Sync calendars → iCal export link (if you use Booking)
BOOKING_ICAL_URL=

# --- Marketing agent (Instagram + Canva) — optional; never commit real tokens ---
# Dry run works without these. Set MARKETING_AGENT_PUBLISH=true only when Lana approves auto-posting.
MARKETING_AGENT_PUBLISH=
SITE_URL=https://villa-augflor.com
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
CANVA_ACCESS_TOKEN=
CANVA_BRAND_TEMPLATE_FEED=
CANVA_BRAND_TEMPLATE_STORY=
CANVA_BRAND_TEMPLATE_REEL=
